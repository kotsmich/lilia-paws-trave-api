<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    body { font-family: Arial, sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .card { background: #fff; border-radius: 8px; max-width: 560px; margin: 0 auto; padding: 32px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .header { border-bottom: 3px solid #c47c3e; padding-bottom: 16px; margin-bottom: 24px; }
    .header h2 { margin: 0; color: #2d2016; font-size: 20px; }
    .header p { margin: 4px 0 0; color: #7a6358; font-size: 13px; }
    .row { margin-bottom: 14px; }
    .label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #c47c3e; margin-bottom: 3px; }
    .value { font-size: 15px; color: #2d2016; }
    .cta { margin-top: 24px; text-align: center; }
    .cta a { display: inline-block; background: #c47c3e; color: #fff; text-decoration: none; padding: 12px 28px; border-radius: 6px; font-size: 15px; font-weight: 600; }
    .footer { margin-top: 28px; font-size: 12px; color: #aaa; border-top: 1px solid #eee; padding-top: 16px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <h2>🐾 New Trip Request</h2>
      <p>Submitted via liliapawstravel.com</p>
    </div>

    <div class="row">
      <div class="label">Name</div>
      <div class="value">{{requesterName}}</div>
    </div>
    <div class="row">
      <div class="label">Email</div>
      <div class="value"><a href="mailto:{{requesterEmail}}" style="color:#c47c3e">{{requesterEmail}}</a></div>
    </div>
    <div class="row">
      <div class="label">Phone</div>
      <div class="value">{{requesterPhone}}</div>
    </div>
    <div class="row">
      <div class="label">Dogs</div>
      <div class="value">{{dogsCount}} dog(s)</div>
    </div>

    <div class="cta">
      <a href="{{adminUrl}}/admin/requests">Review in Admin Panel</a>
    </div>

    <div class="footer">Submitted: {{submittedAt}}</div>
  </div>
</body>
</html>
