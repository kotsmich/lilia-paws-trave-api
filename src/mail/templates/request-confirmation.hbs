<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    body { font-family: Arial, sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .card { background: #fff; border-radius: 8px; max-width: 560px; margin: 0 auto; padding: 32px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .header { border-bottom: 3px solid #c47c3e; padding-bottom: 16px; margin-bottom: 24px; }
    .header h2 { margin: 0; color: #2d2016; font-size: 20px; }
    .header p { margin: 4px 0 0; color: #7a6358; font-size: 13px; }
    .banner { background: #fef9f0; border-radius: 6px; padding: 14px 18px; margin-bottom: 24px; color: #4a3728; font-size: 15px; line-height: 1.5; }
    .row { margin-bottom: 14px; }
    .label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #c47c3e; margin-bottom: 3px; }
    .value { font-size: 15px; color: #2d2016; }
    .dog-card { background: #fafafa; border: 1px solid #ece3d8; border-radius: 6px; padding: 14px 16px; margin-bottom: 10px; }
    .dog-name { font-weight: 700; color: #2d2016; font-size: 15px; margin-bottom: 6px; }
    .dog-detail { font-size: 13px; color: #7a6358; margin-bottom: 2px; }
    .section-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #c47c3e; margin: 24px 0 10px; }
    .footer { margin-top: 28px; font-size: 12px; color: #aaa; border-top: 1px solid #eee; padding-top: 16px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <h2>🐾 Lilia Paws Travel</h2>
      <p>Trip Request Received</p>
    </div>

    <div class="banner">
      Hi <strong>{{requesterName}}</strong>, thank you for your request!<br/>
      We have received it and will review it as soon as possible. You will be notified at this email address once a decision has been made.
    </div>

    <div class="row">
      <div class="label">Name</div>
      <div class="value">{{requesterName}}</div>
    </div>

    {{#if tripRoute}}
    <div class="row">
      <div class="label">Trip Route</div>
      <div class="value">{{tripRoute}}</div>
    </div>
    {{/if}}

    {{#if tripDate}}
    <div class="row">
      <div class="label">Trip Date</div>
      <div class="value">{{tripDate}}</div>
    </div>
    {{/if}}

    {{#if dogs.length}}
    <div class="section-title">Your Dogs ({{dogs.length}})</div>
    {{#each dogs}}
    <div class="dog-card">
      <div class="dog-name">{{name}}</div>
      <div class="dog-detail">Size: {{size}} &nbsp;|&nbsp; Age: {{age}} yr(s)</div>
      <div class="dog-detail">Chip ID: {{chipId}}</div>
      <div class="dog-detail">Pickup: {{pickupLocation}}</div>
      <div class="dog-detail">Drop-off: {{dropLocation}}</div>
      {{#if notes}}<div class="dog-detail" style="margin-top:4px;font-style:italic">{{notes}}</div>{{/if}}
    </div>
    {{/each}}
    {{/if}}

    <div class="footer">liliapawstravel.com</div>
  </div>
</body>
</html>
